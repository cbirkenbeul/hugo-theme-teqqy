{{- $pctx := . -}}
{{- if .IsHome -}}{{ $pctx = .Site }}{{- end -}}
{{- $pages := slice -}}
{{- if or $.IsHome $.IsSection -}}
{{ $pages = $pctx.RegularPages }}
{{- else -}}
{{ $pages = $pctx.Pages }}
{{- end -}}
{{- $pages = $pages | first 20 -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ if ne .Title .Site.Title }}{{ .Title }} – {{ end }}{{ .Site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ .Site.Params.description }}</description>
    <language>{{ .Lang }}</language>
    <managingEditor>{{ .Site.Params.author }}</managingEditor>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <generator>Hugo {{ hugo.Version }}</generator>
    {{ with .OutputFormats.Get "RSS" -}}
    <atom:link href="{{ .Permalink }}" rel="self" type="{{ .MediaType.Type }}" />
    {{- end }}
    {{ range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      {{ with .Lastmod }}<lastBuildDate>{{ .Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>{{ end }}
      <guid isPermaLink="true">{{ .Permalink }}</guid>
      <description>{{ .Summary | plainify | html }}</description>
      <content:encoded><![CDATA[{{ .Content }}]]></content:encoded>
      {{ range .Params.tags }}<category>{{ . }}</category>
      {{ end }}
    </item>
    {{ end }}
  </channel>
</rss>
