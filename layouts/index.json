{{- $pages := where .Site.RegularPages "Draft" false -}}
[
  {{- range $i, $p := $pages -}}
  {{- if $i -}},{{- end -}}
  {
    "title": {{ $p.Title | jsonify }},
    "permalink": {{ $p.RelPermalink | jsonify }},
    "summary": {{ $p.Summary | plainify | jsonify }},
    "content": {{ $p.Plain | truncate 300 | jsonify }},
    "tags": {{ $p.Params.tags | default (slice) | jsonify }},
    "date": {{ $p.Date.Format "2006-01-02" | jsonify }}
  }
  {{- end -}}
]
